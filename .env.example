# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=charity_user
POSTGRES_PASSWORD=charity_pass
POSTGRES_DB=charity_cms

# ── Security ─────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── First Admin (auto-created on first run) ───────────────────────────────────
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_PASSWORD=Admin@123
FIRST_SUPERUSER_EMAIL=admin@charity.org

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
